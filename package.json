{
  "name": "the-hub",
  "version": "0.1.0",
  "description": "A config-driven personal command center — index your workspaces, search everything, get AI-powered insights.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ahmedkhaledmohamed/the-hub"
  },
  "keywords": [
    "knowledge-base",
    "personal-hub",
    "workspace",
    "command-center",
    "ai",
    "mcp",
    "nextjs"
  ],
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "the-hub": "./bin/the-hub.js",
    "hub": "./bin/hub.js",
    "hub-mcp": "./bin/hub-mcp.js"
  },
  "files": [
    "bin/",
    "src/",
    "public/",
    "server.mjs",
    "next.config.ts",
    "hub.config.example.ts",
    "tsconfig.json",
    "postcss.config.mjs",
    "Dockerfile",
    "docker-compose.yml",
    "LICENSE"
  ],
  "scripts": {
    "mcp": "tsx src/mcp/server.ts",
    "dev": "next dev --turbopack -p 9001",
    "build": "next build",
    "start": "NODE_ENV=production node server.mjs",
    "start:http": "next start -p 9001",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-scroll-area": "^1.2.3",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tooltip": "^1.1.8",
    "better-sqlite3": "^12.8.0",
    "chokidar": "^4.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "glob": "^11.0.1",
    "highlight.js": "^11.11.1",
    "lucide-react": "^0.475.0",
    "marked": "^15.0.7",
    "marked-highlight": "^2.2.1",
    "minimatch": "^10.2.5",
    "next": "^15.3.0",
    "pdf-parse": "^2.4.5",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.0.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.13.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  }
}
